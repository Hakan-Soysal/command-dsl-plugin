        {
            "id": "CancelPendingOrder",
            "kind": "command",
            "signature": {
                "actor": "Customer",
                "verb": "cancels",
                "ownership": "own",
                "resource": "Order"
            },
            "delegation": null,
            "target": null,
            "source": null,
            "recipient": null,
            "description": "İptal penceresi DSL'de 'only if Order.age <= 1 hour' ile sınırlı; gerçek\niade SLA'sı (24s) ve 3DS geri-ödeme akışı DSL dışıdır — handler ödeme\nsağlayıcısının iade webhook'unu beklemeli, senkron yanıt varsaymamalı.",
            "schedule": null,
            "orderBy": null,
            "limit": null,
            "guards": [
                {
                    "id": "where:0",
                    "kind": "where",
                    "text": "status = 'pending'",
                    "ast": {
                        "node": "cmp",
                        "op": "=",
                        "left": {
                            "path": [
                                "status"
                            ]
                        },
                        "right": {
                            "kind": "string",
                            "value": "pending"
                        }
                    }
                },
                {
                    "id": "during:0",
                    "kind": "during",
                    "calendar": "business-hours"
                },
                {
                    "id": "if:0",
                    "kind": "if",
                    "text": "Order.age <= 1 hour",
                    "ast": {
                        "node": "cmp",
                        "op": "<=",
                        "left": {
                            "path": [
                                "Order",
                                "age"
                            ]
                        },
                        "right": {
                            "kind": "duration",
                            "value": 1,
                            "unit": "hour",
                            "text": "1 hour"
                        }
                    }
                }
            ],
            "calculate": [],
            "effects": [
                {
                    "kind": "calculate",
                    "target": [
                        "Refund",
                        "amount"
                    ],
                    "text": "Order.total * 0.90",
                    "expr": {
                        "node": "mul",
                        "op": "*",
                        "left": {
                            "path": [
                                "Order",
                                "total"
                            ]
                        },
                        "right": {
                            "kind": "number",
                            "value": 0.9
                        }
                    },
                    "condition": {
                        "text": "Order.payment = 'credit'",
                        "ast": {
                            "node": "cmp",
                            "op": "=",
                            "left": {
                                "path": [
                                    "Order",
                                    "payment"
                                ]
                            },
                            "right": {
                                "kind": "string",
                                "value": "credit"
                            }
                        }
                    }
                },
                {
                    "kind": "send",
                    "message": "CancellationConfirmation",
                    "recipient": [
                        "Order",
                        "owner"
                    ]
                },
                {
                    "kind": "perform",
                    "target": "IssueGiftCard"
                }
            ],
            "access": {
                "writes": [
                    "Order",
                    "Refund"
                ],
                "reads": []
            },
            "flows": [
                "CancelOrder"
            ],
            "processes": [],
            "domain": "OrderManagement"
        },
