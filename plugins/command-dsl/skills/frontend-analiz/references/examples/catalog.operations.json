        {
            "id": "CalculateCommission",
            "kind": "command",
            "signature": {
                "actor": "System",
                "verb": "calculates",
                "ownership": "any",
                "resource": "Commission"
            },
            "delegation": null,
            "target": null,
            "source": null,
            "recipient": null,
            "description": null,
            "schedule": null,
            "orderBy": null,
            "limit": null,
            "guards": [],
            "calculate": [
                {
                    "target": [
                        "Commission",
                        "amount"
                    ],
                    "text": "Order.total * 0.10",
                    "expr": {
                        "node": "mul",
                        "op": "*",
                        "left": {
                            "path": [
                                "Order",
                                "total"
                            ]
                        },
                        "right": {
                            "kind": "number",
                            "value": 0.1
                        }
                    },
                    "condition": {
                        "text": "Order.total < 1000",
                        "ast": {
                            "node": "cmp",
                            "op": "<",
                            "left": {
                                "path": [
                                    "Order",
                                    "total"
                                ]
                            },
                            "right": {
                                "kind": "number",
                                "value": 1000
                            }
                        }
                    }
                },
                {
                    "target": [
                        "Commission",
                        "amount"
                    ],
                    "text": "Order.total * 0.08",
                    "expr": {
                        "node": "mul",
                        "op": "*",
                        "left": {
                            "path": [
                                "Order",
                                "total"
                            ]
                        },
                        "right": {
                            "kind": "number",
                            "value": 0.08
                        }
                    },
                    "condition": {
                        "text": "Order.total >= 1000",
                        "ast": {
                            "node": "cmp",
                            "op": ">=",
                            "left": {
                                "path": [
                                    "Order",
                                    "total"
                                ]
                            },
                            "right": {
                                "kind": "number",
                                "value": 1000
                            }
                        }
                    }
                }
            ],
            "effects": [],
            "access": {
                "writes": [
                    "Commission"
                ],
                "reads": [
                    "Order"
                ]
            },
            "flows": [],
            "processes": [],
            "domain": "Calculations"
        },
        {
            "id": "CalculateInvoiceTotal",
            "kind": "command",
            "signature": {
                "actor": "System",
                "verb": "calculates",
                "ownership": "own",
                "resource": "Invoice"
            },
            "delegation": null,
            "target": null,
            "source": null,
            "recipient": null,
            "description": null,
            "schedule": null,
            "orderBy": null,
            "limit": null,
            "guards": [],
            "calculate": [
                {
                    "target": [
                        "Invoice",
                        "total"
                    ],
                    "text": "sum of Invoice.items.price * 1.20",
                    "expr": {
                        "node": "mul",
                        "op": "*",
                        "left": {
                            "node": "agg",
                            "fn": "sum",
                            "path": [
                                "Invoice",
                                "items",
                                "price"
                            ]
                        },
                        "right": {
                            "kind": "number",
                            "value": 1.2
                        }
                    },
                    "condition": null
                }
            ],
            "effects": [],
            "access": {
                "writes": [
                    "Invoice"
                ],
                "reads": []
            },
            "flows": [],
            "processes": [],
            "domain": "Calculations"
