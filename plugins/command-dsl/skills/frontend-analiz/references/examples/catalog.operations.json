    "rules": [
        {
            "id": "NoUnpaidInvoice",
            "reads": [
                {
                    "kind": "entity",
                    "entity": "Invoice",
                    "alias": "inv"
                }
            ],
            "body": {
                "node": "exists",
                "negated": true,
                "collection": "inv",
                "where": {
                    "node": "cmp",
                    "op": "=",
                    "left": {
                        "path": [
                            "inv",
                            "paid"
                        ]
                    },
                    "right": {
                        "kind": "string",
                        "value": "no"
                    }
                }
            },
            "note": "Ödenmemiş fatura (paid = 'no') varken bu işleme izin verilmez — finansal ön-koşul; kök ilişki yok, niceleyici tüm Invoice kümesi üzerinde koşar."
        }
